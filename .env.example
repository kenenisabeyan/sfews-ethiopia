# ==========================================
# SFEWS Environment Configuration
# ==========================================

# --- Backend Configuration ---
ENVIRONMENT=development
API_V1_STR=/api/v1
SECRET_KEY=your-super-secret-key-change-me

# --- Database Configuration (PostgreSQL) ---
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=sfews_db
POSTGRES_PORT=5432
# Optional: Full URL format used by SQLAlchemy
# DATABASE_URL=postgresql://postgres:your_db_password@localhost:5432/sfews_db

# --- Frontend Configuration ---
# Vite environment variables MUST be prefixed with VITE_
VITE_API_BASE_URL=http://localhost:8000
VITE_MAP_API_KEY=your-map-provider-api-key

# --- Hardware/IoT Configuration (Optional) ---
MQTT_BROKER_URL=mqtt://broker.hivemq.com
MQTT_PORT=1883
MQTT_TOPIC_SENSORS=sfews/sensors/data
